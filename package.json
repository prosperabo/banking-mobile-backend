{
  "name": "banking-mobile-backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/src/index.js",
  "scripts": {
    "start": "node dist/src/index.js",
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/index.ts",
    "build": "tsc && copyfiles \"public/**\" dist/",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:auth-flow": "node scripts/verify-auth-flow-guard.js",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "orm:init": "npx prisma init",
    "orm:generate": "npx prisma generate",
    "orm:migrate:dev": "npx prisma migrate dev",
    "orm:migrate:deploy": "npx prisma migrate deploy",
    "prepare": "node -e \"process.env.HUSKY === '0' && process.exit(0)\" || husky",
    "audit:check": "better-npm-audit audit --level high",
    "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts npm --validate-https",
    "audit:all": "npm run audit:check && npm run lint:lockfile"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.10.0"
  },
  "keywords": [
    "banking",
    "mobile",
    "backend",
    "typescript",
    "express",
    "prisma"
  ],
  "author": "Prospera Servicios Financieros",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git@github.com-personal:prosperabo/banking-mobile-backend.git"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.16.0",
    "@prisma/client": "^6.5.0",
    "@types/axios": "^0.9.36",
    "axios": "^1.12.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "express-validator": "^7.2.1",
    "firebase-admin": "^13.8.0",
    "form-data": "^4.0.5",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.2.3",
    "moment-timezone": "^0.6.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.2",
    "puppeteer": "^24.41.0",
    "resend": "^4.2.0",
    "source-map-support": "^0.5.21",
    "ulid": "^3.0.2",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/form-data": "^2.2.1",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/module-alias": "^2.0.4",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "better-npm-audit": "^3.11.0",
    "copyfiles": "^2.4.1",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lockfile-lint": "^5.0.0",
    "prettier": "^3.5.3",
    "prisma": "^6.5.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.10",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "8.60.1"
  },
  "_moduleAliases": {
    "@": "dist/src"
  }
}
